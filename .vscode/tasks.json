{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Run Streamlit App",
      "type": "shell",
      "command": "python",
      "args": [
        "-m",
        "streamlit",
        "run",
        "${workspaceFolder}\\app.py",
        "--server.port",
        "8501"
      ],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "problemMatcher": []
    }
  ]
}
